rules_version = '2';

// Water Ring Puzzle Game — Firestore Security Rules
// Implements Requirements 26.3, 26.4, 26.5, 26.6, 26.7
//
// Rule summary:
//   /players/{userId}                          — owner read/write only (Req 26.3)
//   /players/{userId}/challenges/{N}           — owner read/write only (Req 26.3)
//   /players/{userId}/mastery/{templateId}     — owner read/write only (Req 26.3)
//   /leaderboards/{id}/entries/{entryUserId}   — authenticated read; Cloud Functions write only (Req 26.4)
//   /economy/{txId}                            — owner read only; Cloud Functions write only (Req 26.5)
//   /challenge_intelligence/{N}               — authenticated read; Cloud Functions write only (Req 26.6)
//   All other paths                            — deny all (Req 26.7)

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ─────────────────────────────────────────────────────

    /// Returns true when the request carries a valid Firebase Auth token.
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }

    /// Returns true when the requester's uid matches the given userId.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── Player documents ─────────────────────────────────────────────────────
    // Req 26.3: readable/writable only by the authenticated user whose uid
    //           matches the document ID.

    match /players/{userId} {
      allow read, write: if isOwner(userId);

      // Sub-collection: per-challenge progress
      // Req 26.3 (scoped to owning user)
      match /challenges/{challengeId} {
        allow read, write: if isOwner(userId);
      }

      // Sub-collection: mastery data per template
      // Req 26.3 (scoped to owning user)
      match /mastery/{templateId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─── Leaderboard entries ──────────────────────────────────────────────────
    // Req 26.4: readable by all authenticated users; NO client writes —
    //           writes come exclusively from Cloud Functions via Admin SDK
    //           (Admin SDK bypasses security rules, so denying all client
    //           writes here is correct and sufficient).

    match /leaderboards/{leaderboardId} {
      allow read: if isAuthenticated();
      allow write: if false;

      match /entries/{entryUserId} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
    }

    // ─── Economy transactions ─────────────────────────────────────────────────
    // Req 26.5: readable only by the transaction owner (document must carry a
    //           userId field); NO client writes.

    match /economy/{txId} {
      allow read: if isAuthenticated()
                  && resource != null
                  && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ─── Challenge intelligence ───────────────────────────────────────────────
    // Req 26.6: readable by all authenticated users; NO client writes.

    match /challenge_intelligence/{challengeNumber} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── Catch-all: deny everything else ─────────────────────────────────────
    // Req 26.7: all reads and writes require a valid Firebase Auth token;
    //           any path not explicitly covered above is denied.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
