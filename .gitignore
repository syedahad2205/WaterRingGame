# ─── Firebase — NEVER commit real credential files ──────────────────────────
# Placeholder files ARE committed (they contain no real credentials)
# Real files should be added after project setup — add them to this list:
# google-services.json        # real Android Firebase config
# GoogleService-Info.plist    # real iOS Firebase config
# .firebaserc                 # already committed (contains only project IDs)

# Firebase emulator data
WaterRingPuzzleGame/.firebase/
firebase-debug.log
